{% comment %}
  SECTION: Newsletter Hero (Image + Overlay) — No Social
  File: sections/newsletter-hero.liquid
{% endcomment %}

<section class="newsletter-hero newsletter-hero--{{ section.id }}">
  <div
    class="newsletter-hero__bg"
    style="
      {% if section.settings.bg_image != blank %}
        background-image: url({{ section.settings.bg_image | image_url: width: 3000 }});
      {% endif %}
      background-position: {{ section.settings.bg_position }};
      background-size: cover;
      background-repeat: no-repeat;
    "
    role="img"
    aria-label="{{ section.settings.bg_alt | escape }}"
  ></div>

  <div class="newsletter-hero__overlay"></div>

  <div class="newsletter-hero__container">
    <div class="newsletter-hero__content">
      {% if section.settings.kicker != blank %}
        <p class="newsletter-hero__kicker">{{ section.settings.kicker }}</p>
      {% endif %}

      {% if section.settings.heading != blank %}
        <h2 class="newsletter-hero__heading">{{ section.settings.heading }}</h2>
      {% endif %}

      {% if section.settings.subheading != blank %}
        <p class="newsletter-hero__subheading">{{ section.settings.subheading }}</p>
      {% endif %}

      {% if section.settings.newsletter_enable %}
        <div class="newsletter-hero__formwrap">
          {%- form 'customer', id: 'ContactNewsletterHero-' | append: section.id, class: 'newsletter-hero__form newsletter-form' -%}
            <input type="hidden" name="contact[tags]" value="newsletter">
            <div class="newsletter-form__field-wrapper">
              <div class="field">
                <input
                  id="NewsletterForm-{{ section.id }}"
                  type="email"
                  name="contact[email]"
                  class="field__input"
                  value="{{ form.email }}"
                  aria-required="true"
                  autocorrect="off"
                  autocapitalize="off"
                  autocomplete="email"
                  {% if form.errors %} autofocus aria-invalid="true" aria-describedby="NewsletterHero-error-{{ section.id }}"{% elsif form.posted_successfully? %} aria-describedby="NewsletterHero-success-{{ section.id }}"{% endif %}
                  placeholder="{{ section.settings.email_placeholder }}"
                  required
                >
                <label class="field__label" for="NewsletterForm-{{ section.id }}">{{ section.settings.email_placeholder }}</label>

                <button
                  type="submit"
                  class="newsletter-form__button field__button"
                  name="commit"
                  id="Subscribe-{{ section.id }}"
                  aria-label="{{ section.settings.button_label }}"
                >
                  <span class="btn-label">{{ section.settings.button_label }}</span>
                </button>
              </div>

              {% if form.errors %}
                <small class="newsletter-form__message form__message" id="NewsletterHero-error-{{ section.id }}">
                  {{ form.errors.translated_fields.email | capitalize }} {{ form.errors.messages.email }}
                </small>
              {% endif %}
            </div>

            {% if form.posted_successfully? %}
              <h3 class="newsletter-form__message newsletter-form__message--success form__message" id="NewsletterHero-success-{{ section.id }}" tabindex="-1" autofocus>
                {{ section.settings.success_text }}
              </h3>
            {% endif %}
          {%- endform -%}
        </div>
      {% endif %}
    </div>
  </div>

  <style>
    .newsletter-hero--{{ section.id }}{
      position: relative; isolation: isolate; color: {{ section.settings.text_color }};
      min-height: {{ section.settings.min_height }}px;
    }
    .newsletter-hero--{{ section.id }} .newsletter-hero__bg{
      position:absolute; inset:0; z-index:0; filter: blur({{ section.settings.bg_blur }}px);
      background-color:#000; /* fallback */
    }
    .newsletter-hero--{{ section.id }} .newsletter-hero__overlay{
      position:absolute; inset:0; z-index:1;
      background: {{ section.settings.overlay_color }};
      opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    }
    .newsletter-hero--{{ section.id }} .newsletter-hero__container{
      position:relative; z-index:2; max-width: {{ section.settings.max_width }}px;
      margin:0 auto; text-align: {{ section.settings.alignment }};
      padding: {{ section.settings.padding_y_desktop }}px {{ section.settings.padding_x }}px;
      display:flex; align-items:center; justify-content:center; height:100%;
    }
    @media (max-width: 749px){
      .newsletter-hero--{{ section.id }} .newsletter-hero__container{
        padding: {{ section.settings.padding_y_mobile }}px {{ section.settings.padding_x }}px;
      }
    }
    .newsletter-hero__kicker{
      letter-spacing:.12em; text-transform:uppercase; opacity:.9; margin:0 0 .5rem;
      font-weight:700; font-size:clamp(12px,2.2vw,14px);
    }
    .newsletter-hero__heading{
      margin:0 0 .8rem; line-height:1.05; font-weight:900;
      text-transform:uppercase; font-style:italic;
      font-size:clamp(28px,4vw,52px);
      text-shadow:0 2px 12px rgba(0,0,0,.35);
    }
    .newsletter-hero__subheading{ margin:0 0 1.4rem; opacity:.9; font-size:clamp(14px,2.2vw,18px); }

    /* Form */
    .newsletter-hero__formwrap{ max-width: 820px; margin:0 auto 1.25rem; }
    .newsletter-hero__form .field{ position:relative; display:flex; align-items:stretch; gap:10px; }
    .newsletter-hero__form .field__input{
      flex:1 1 auto; height:56px; border-radius:8px; border:none; outline:none;
      padding:0 16px; font-size:16px; background:rgba(255,255,255,.12);
      color: {{ section.settings.text_color }}; backdrop-filter: blur(2px);
    }
    .newsletter-hero__form .field__input::placeholder{ color: {{ section.settings.text_color }}; opacity:.75; }
    .newsletter-hero__form .field__label{ display:none; }
    .newsletter-hero__form .newsletter-form__button{
      height:56px; min-width:170px; border-radius:8px; border:0; cursor:pointer;
      padding:0 18px; font-weight:900; text-transform:uppercase;
      background: {{ section.settings.button_bg }}; color: {{ section.settings.button_text }};
      transition: transform .08s ease, opacity .2s ease, filter .2s ease;
      box-shadow: 0 6px 0 rgba(0,0,0,.25);
    }
    .newsletter-hero__form .newsletter-form__button:hover{ transform: translateY(-1px); opacity:.96; }
    .newsletter-hero__form .newsletter-form__button:active{ transform: translateY(1px); box-shadow:none; }
  </style>
</section>

{% schema %}
{
  "name": "Newsletter Hero (Overlay)",
  "class": "section--newsletter-hero",
  "settings": [
   
  ],
  "blocks": [],
  "presets": [
    { "name": "Newsletter Hero (Overlay)", "category": "Promotional" }
  ]
}
{% endschema %}
