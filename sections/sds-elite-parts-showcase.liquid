<style>
  .elite-parts-section {
    background-color: #0A0A0A;
    padding: 6rem 5rem;
  }
  .elite-parts-header {
    text-align: center;
    margin-bottom: 4rem;
  }
  .elite-parts-title {
    font-family: 'Racing Sans One', cursive;
    font-size: clamp(3rem, 5vw, 4rem);
    color: #FFF;
    text-transform: uppercase;
    font-style: italic;
    line-height: 1;
    margin-bottom: 1rem;
  }
  .elite-parts-subtitle {
    font-family: 'Roboto Mono', monospace;
    color: #888;
    font-size: 14px;
    max-width: 600px;
    margin: 0 auto;
  }
  .elite-parts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 2rem;
    max-width: 1400px;
    margin: 0 auto;
  }
  .elite-part-card {
    background-color: #111508;
    border: 1px solid #333;
    overflow: hidden;
    position: relative;
    transition: all 0.3s ease;
    display: flex;
    flex-direction: column;
    text-decoration: none;
  }
  .elite-part-card:hover {
    border-color: #CCFF00;
    box-shadow: 0 0 20px rgba(204, 255, 0, 0.15);
  }
  .elite-part-img-wrapper {
    position: relative;
    width: 100%;
    padding-top: 75%; /* 4:3 Aspect Ratio */
    overflow: hidden;
    background-color: #000;
  }
  .elite-part-img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.8;
    transition: transform 0.5s ease, opacity 0.5s ease;
  }
  .elite-part-card:hover .elite-part-img {
    transform: scale(1.05);
    opacity: 1;
  }
  .elite-part-content {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }
  .elite-part-sku {
    font-family: 'Roboto Mono', monospace;
    font-size: 12px;
    color: #CCFF00;
    margin-bottom: 0.5rem;
  }
  .elite-part-name {
    font-family: 'Racing Sans One', cursive;
    font-size: 1.8rem;
    color: #FFF;
    text-transform: uppercase;
    font-style: italic;
    margin: 0 0 1rem 0;
    line-height: 1.1;
  }
  .elite-part-footer {
    margin-top: auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-top: 1px dashed #333;
    padding-top: 1rem;
  }
  .elite-part-price {
    font-family: 'Roboto Mono', monospace;
    color: #FFF;
    font-size: 16px;
    font-weight: 500;
  }
  .elite-part-btn {
    font-family: 'Roboto Mono', monospace;
    font-size: 12px;
    color: #0A0A0A;
    background-color: #CCFF00;
    padding: 6px 12px;
    text-transform: uppercase;
    font-weight: bold;
    transition: background-color 0.3s ease;
  }
  .elite-part-card:hover .elite-part-btn {
    background-color: #FFF;
  }
  
  @media (max-width: 768px) {
    .elite-parts-section {
      padding: 4rem 1.5rem;
    }
  }
</style>

<section class="elite-parts-section">
  <div class="elite-parts-header">
    <h2 class="elite-parts-title">{{ section.settings.heading }}</h2>
    <p class="elite-parts-subtitle">{{ section.settings.subheading }}</p>
  </div>

  <div class="elite-parts-grid">
    {% for block in section.blocks %}
      <a href="{{ block.settings.link | default: '#' }}" class="elite-part-card" {{ block.shopify_attributes }}>
        <div class="elite-part-img-wrapper">
          {% if block.settings.image != blank %}
            {{ block.settings.image | image_url: width: 800 | image_tag: class: 'elite-part-img', loading: 'lazy' }}
          {% else %}
            <div class="elite-part-img" style="background-color: #1A1A1A; display: flex; align-items: center; justify-content: center; color: #333; font-family: 'Roboto Mono', monospace;">[IMAGE REQUIRED]</div>
          {% endif %}
        </div>
        <div class="elite-part-content">
          <div class="elite-part-sku">{{ block.settings.sku }}</div>
          <h3 class="elite-part-name">{{ block.settings.title }}</h3>
          <div class="elite-part-footer">
            <span class="elite-part-price">{{ block.settings.price }}</span>
            <span class="elite-part-btn">View Specs</span>
          </div>
        </div>
      </a>
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "SDS Elite - Parts Gallery",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Component Catalog"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "BROWSE INDIVIDUAL AERODYNAMIC COMPONENTS ENGINEERED FOR PRECISION FITMENT."
    }
  ],
  "blocks": [
    {
      "type": "part",
      "name": "Car Part",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Part Image"
        },
        {
          "type": "text",
          "id": "sku",
          "label": "Spec/SKU Tag",
          "default": "SYS: 1X1 CF"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Part Name",
          "default": "VENTED HOOD"
        },
        {
          "type": "text",
          "id": "price",
          "label": "Price / Value",
          "default": "$4,200.00"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link to Product"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "SDS Elite - Parts Gallery",
      "blocks": [
        { "type": "part", "settings": { "title": "VENTED HOOD", "sku": "SYS: 1X1 CF", "price": "$4,200.00" } },
        { "type": "part", "settings": { "title": "AERO DISCS", "sku": "SYS: FORGED", "price": "$2,800.00" } },
        { "type": "part", "settings": { "title": "GT3 WING", "sku": "SYS: 2X2 CF", "price": "$6,500.00" } }
      ]
    }
  ]
}
{% endschema %}
