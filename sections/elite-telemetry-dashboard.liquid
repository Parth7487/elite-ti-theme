<!-- WATERMARK: CREATED BY ANTIGRAVITY -->
<section class="elite-telemetry-section py-16 border-b" style="border-color: #333; background-color: #0A0A0A; padding-top: 4rem; padding-bottom: 4rem;">
  <div class="max-w-container-max mx-auto grid grid-cols-1 md:grid-cols-3 gap-6" style="max-width: 1400px; padding: 0 5rem; display: grid; gap: 1.5rem; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));">
    
    {%- for block in section.blocks -%}
      <div class="border p-8 relative group transition-all duration-300" style="border-color: #333; background-color: #1A1A1A; padding: 2rem;">
        
        <div class="absolute top-2 right-2 transition-colors" style="font-family: 'Roboto Mono', monospace; font-size: 10px; color: #555;">{{ block.settings.stream_id }}</div>
        
        <div class="uppercase mb-2" style="font-family: 'Roboto Mono', monospace; font-size: 14px; color: #888;">{{ block.settings.title }}</div>
        
        <div class="text-primary-container group-hover:animate-pulse" style="font-family: 'Roboto Mono', monospace; font-size: 32px; font-weight: 500; color: #CCFF00; line-height: 1;">
          {{ block.settings.stat_value }}
        </div>
        
        {%- if block.settings.show_progress_bar -%}
        <div class="mt-4 w-full h-1 overflow-hidden flex gap-1" style="height: 4px; display: flex; gap: 4px; margin-top: 1rem;">
          <div class="h-full bg-primary-container" style="background-color: #CCFF00; width: {{ block.settings.progress_percent }}%;"></div>
          <div class="h-full bg-surface-container flex-1" style="background-color: #333; flex: 1;"></div>
        </div>
        {%- endif -%}

        {%- if block.settings.show_segmented_bar -%}
        <div class="mt-4 w-full flex gap-1 h-1" style="height: 4px; display: flex; gap: 4px; margin-top: 1rem;">
          <div class="h-full bg-primary-container flex-1" style="background-color: #CCFF00; flex: 1;"></div>
          <div class="h-full bg-primary-container flex-1" style="background-color: #CCFF00; flex: 1;"></div>
          <div class="h-full bg-primary-container flex-1" style="background-color: #CCFF00; flex: 1;"></div>
          <div class="h-full bg-primary-container flex-1" style="background-color: #CCFF00; flex: 1;"></div>
          <div class="h-full bg-surface-container flex-1" style="background-color: #333; flex: 1;"></div>
        </div>
        {%- endif -%}

        {%- if block.settings.bottom_note != blank -%}
        <div class="mt-4 flex items-center gap-2" style="margin-top: 1rem; display: flex; align-items: center; gap: 0.5rem;">
          <span style="color: #CCFF00; font-family: 'Roboto Mono', monospace; font-size: 14px;">[+]</span>
          <span class="text-xs uppercase" style="font-family: 'Roboto Mono', monospace; font-size: 12px; color: #888;">{{ block.settings.bottom_note }}</span>
        </div>
        {%- endif -%}

      </div>
    {%- endfor -%}

  </div>
</section>

<style>
  .elite-telemetry-section .group:hover {
    border-color: #CCFF00 !important;
    box-shadow: 0 0 20px rgba(204, 255, 0, 0.2);
  }
  .elite-telemetry-section .group:hover .transition-colors {
    color: #CCFF00 !important;
  }
</style>

{% schema %}
{
  "name": "Elite - Telemetry Data",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Telemetry Dashboard Settings"
    }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Telemetry Stat Card",
      "settings": [
        {
          "type": "text",
          "id": "stream_id",
          "label": "Stream ID (Top Right)",
          "default": "DATA_STREAM_01"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Stat Title",
          "default": "Weight Reduction"
        },
        {
          "type": "text",
          "id": "stat_value",
          "label": "Stat Value",
          "default": "-15.4 kg"
        },
        {
          "type": "checkbox",
          "id": "show_progress_bar",
          "label": "Show Continuous Progress Bar",
          "default": true
        },
        {
          "type": "range",
          "id": "progress_percent",
          "min": 0,
          "max": 100,
          "step": 5,
          "unit": "%",
          "label": "Progress Percentage",
          "default": 85
        },
        {
          "type": "checkbox",
          "id": "show_segmented_bar",
          "label": "Show Segmented Bar Instead",
          "default": false
        },
        {
          "type": "text",
          "id": "bottom_note",
          "label": "Bottom Note",
          "default": ""
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Elite - Telemetry Data",
      "blocks": [
        { "type": "stat", "settings": { "stream_id": "DATA_STREAM_01", "title": "Weight Reduction", "stat_value": "-15.4 kg", "show_progress_bar": true, "progress_percent": 85, "show_segmented_bar": false } },
        { "type": "stat", "settings": { "stream_id": "DATA_STREAM_02", "title": "Fitment Accuracy", "stat_value": "99.8 %", "show_progress_bar": false, "show_segmented_bar": true } },
        { "type": "stat", "settings": { "stream_id": "DATA_STREAM_03", "title": "Est. Install Time", "stat_value": "2-4 hrs", "show_progress_bar": false, "show_segmented_bar": false, "bottom_note": "CERTIFIED TECH REQ." } }
      ]
    }
  ]
}
{% endschema %}
