<style>
  .elite-aero-wrapper {
    position: relative;
    width: 100%;
    height: 921px;
    min-height: 600px;
    background-color: #111508;
    display: flex;
    align-items: center;
    overflow: hidden;
    border-bottom: 1px solid #444933;
  }
  .elite-aero-bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.5;
    mix-blend-mode: luminosity;
  }
  .elite-hotspot {
    position: absolute;
    z-index: 10;
    cursor: crosshair;
  }
  .elite-hotspot-inner {
    position: relative;
    width: 24px;
    height: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .elite-hotspot-pulse {
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    background-color: #CCFF00;
    border-radius: 50%;
    opacity: 0.75;
    animation: ping 1.5s cubic-bezier(0, 0, 0.2, 1) infinite;
  }
  .elite-hotspot-core {
    position: relative;
    width: 12px;
    height: 12px;
    background-color: #CCFF00;
    border-radius: 50%;
  }
  .elite-tooltip {
    position: absolute;
    bottom: 100%;
    left: 50%;
    transform: translateX(-50%);
    margin-bottom: 1rem;
    width: 12rem;
    opacity: 0;
    transition: opacity 0.3s;
    pointer-events: none;
  }
  .elite-hotspot:hover .elite-tooltip {
    opacity: 1;
  }
  @keyframes ping {
    75%, 100% {
      transform: scale(2);
      opacity: 0;
    }
  }
</style>

<section class="elite-aero-wrapper">
  {%- if section.settings.bg_image != blank -%}
    {{ section.settings.bg_image | image_url: width: 2000 | image_tag: class: 'elite-aero-bg', loading: 'lazy' }}
  {%- else -%}
    <img alt="Elite Ti Aero Supercar" class="elite-aero-bg" src="https://lh3.googleusercontent.com/aida-public/AB6AXuAIyyOV5omTsWEIBWnlgOE5cTG4VXlaPr-idnCYG5dNFyAhUTRvA8BJmvolV3bg_IS9TGNsS_HuayYFcuHztAk78Vvq59HGv4RUXrBMGx72AHR4NGrS4ydWyLR0Qsauy9EOw06fZwzmPHCd2O7OyPtrq1tJ334E3qBjx4UMe-28dj26iLqujUnT_qeakDzAOO0EUaMP9blKo8GHnkx_T-xPjIWpVAKU1Nvk0qIbLyWE61QKfiy_D9WWG-tALwxYAxwhZhK3LM2pwNJj" />
  {%- endif -%}

  {%- for block in section.blocks -%}
    <div class="elite-hotspot" style="top: {{ block.settings.pos_y }}%; left: {{ block.settings.pos_x }}%;">
      <div class="elite-hotspot-inner">
        <div class="elite-hotspot-pulse"></div>
        <div class="elite-hotspot-core"></div>
        <div class="elite-tooltip">
          <div style="background-color: rgba(0,0,0,0.8); backdrop-filter: blur(8px); border: 1px solid #333; padding: 12px; box-shadow: 0 0 20px rgba(204,255,0,0.15);">
            <div style="font-family: 'Roboto Mono', monospace; font-size: 10px; color: #888; text-transform: uppercase; margin-bottom: 4px;">{{ block.settings.label }}</div>
            <div style="font-family: 'Racing Sans One', cursive; color: #FFF; font-style: italic; font-size: 18px; margin-bottom: 8px;">{{ block.settings.title }}</div>
            <div style="font-family: 'Roboto Mono', monospace; color: #CCFF00; font-size: 12px;">{{ block.settings.spec }}</div>
          </div>
          <div style="width: 1px; height: 16px; margin: 0 auto; background-color: #CCFF00;"></div>
        </div>
      </div>
    </div>
  {%- endfor -%}

  <div style="position: relative; z-index: 10; width: 100%; max-width: 1400px; margin: 0 auto; padding-left: 5rem; padding-right: 5rem; pointer-events: none; display: flex; flex-direction: column; justify-content: flex-end; height: 100%; padding-bottom: 8rem;">
    <h1 style="font-family: 'Racing Sans One', cursive; font-size: clamp(4rem, 8vw, 8rem); line-height: 0.9; color: #FFF; text-transform: uppercase; font-style: italic; mix-blend-mode: difference; text-shadow: 0 4px 6px rgba(0,0,0,0.5);">
      {{ section.settings.heading | newline_to_br }}
    </h1>
    <p style="font-family: 'Roboto Mono', monospace; color: #CCFF00; border-left: 2px solid #CCFF00; background-color: rgba(0,0,0,0.5); padding: 8px; margin-top: 1rem; max-width: 400px; font-size: 14px;">
      {{ section.settings.subtext }}
    </p>
  </div>
</section>

{% schema %}
{
  "name": "Elite - Explore Aero",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Image"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "Explore\nAero\nDynamics"
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Subtext",
      "default": "[INTERACT WITH VIRTUAL CHASSIS TO REVEAL TELEMETRY DATA AND COMPONENT SPECS]"
    }
  ],
  "blocks": [
    {
      "type": "hotspot",
      "name": "Hotspot",
      "settings": [
        {
          "type": "range",
          "id": "pos_y",
          "min": 0,
          "max": 100,
          "step": 1,
          "unit": "%",
          "label": "Top Position",
          "default": 50
        },
        {
          "type": "range",
          "id": "pos_x",
          "min": 0,
          "max": 100,
          "step": 1,
          "unit": "%",
          "label": "Left Position",
          "default": 50
        },
        {
          "type": "text",
          "id": "label",
          "label": "Small Label",
          "default": "Component"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Component Title",
          "default": "VENTED HOOD"
        },
        {
          "type": "text",
          "id": "spec",
          "label": "Specification/Price",
          "default": "SYS: 1X1 CF / $4,200"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Elite - Explore Aero",
      "blocks": [
        { "type": "hotspot", "settings": { "pos_y": 45, "pos_x": 30, "title": "VENTED HOOD", "spec": "SYS: 1X1 CF / $4,200" } },
        { "type": "hotspot", "settings": { "pos_y": 75, "pos_x": 15, "title": "AERO DISCS", "spec": "SYS: FORGED / $2,800" } },
        { "type": "hotspot", "settings": { "pos_y": 35, "pos_x": 80, "title": "GT3 WING", "spec": "SYS: 2X2 CF / $6,500" } }
      ]
    }
  ]
}
{% endschema %}
