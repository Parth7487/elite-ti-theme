          "type": "header",
          "content": "Second model"
        },
        {
          "type": "text",
          "id": "model_2",
          "label": "Model 2",
          "default": "RX8"
        },
        {
          "type": "url",
          "id": "model_2_link",
          "label": "Model 2 link"
        },
        {
          "type": "header",
          "content": "Third model"
        },
        {
          "type": "text",
          "id": "model_3",
          "label": "Model 3",
          "default": "MX-5"
        },
        {
          "type": "url",
          "id": "model_3_link",
          "label": "Model 3 link"
        },
        {
          "type": "header",
          "content": "Fourth model"
        },
        {
          "type": "text",
          "id": "model_4",
          "label": "Model 4",
          "default": "CX-5"
        },
        {
          "type": "url",
          "id": "model_4_link",
          "label": "Model 4 link"
        },
        {
          "type": "header",
          "content": "Fifth model"
        },
        {
          "type": "text",
          "id": "model_5",
          "label": "Model 5",
          "default": "CX-30"
        },
        {
          "type": "url",
          "id": "model_5_link",
          "label": "Model 5 link"
        },
        {
          "type": "header",
          "content": "Sixth model"
        },
        {
          "type": "text",
          "id": "model_6",
          "label": "Model 6",
          "default": "CX-90"
        },
        {
          "type": "url",
          "id": "model_6_link",
          "label": "Model 6 link"
        },
        {
